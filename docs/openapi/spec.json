{
  "openapi": "3.0.3",
  "info": {
    "title": "API Financeira",
    "version": "1.0.0",
    "description": "API de gestão financeiros, orientada a eventos."
  },
  "servers": [
    {
      "url": "http://localhost:8082",
      "description": "Local"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Summary",
      "description": "Resumo financeiro do mês"
    },
    {
      "name": "Salary",
      "description": "Detalhamento salarial por competência"
    }
  ],
  "paths": {
    "/api/v1/finance/salary/{competenceDate}/detail": {
      "get": {
        "tags": ["Salary"],
        "summary": "Listar detalhes salariais paginados",
        "operationId": "getSalaryDetail",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/CompetenceDate" },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/Size" }
        ],
        "responses": {
          "200": {
            "description": "Lista paginada de detalhes salariais",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SalaryDetailPageResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "post": {
        "tags": ["Salary"],
        "summary": "Adicionar detalhe salarial",
        "operationId": "addSalaryDetail",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/CompetenceDate" },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/Size" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddSalaryDetailRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Detalhe adicionado. Retorna lista paginada atualizada",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SalaryDetailPageResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "put": {
        "tags": ["Salary"],
        "summary": "Editar detalhe salarial",
        "operationId": "updateSalaryDetail",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/CompetenceDate" },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/Size" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateSalaryDetailRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Detalhe atualizado. Retorna lista paginada atualizada",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SalaryDetailPageResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "delete": {
        "tags": ["Salary"],
        "summary": "Deletar um ou mais detalhes salariais",
        "operationId": "deleteSalaryDetail",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/CompetenceDate" },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/Size" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeleteSalaryDetailRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Detalhes deletados. Retorna lista paginada atualizada",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SalaryDetailPageResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/api/v1/finance/summary/{competenceDate}": {
      "get": {
        "tags": [
          "Summary"
        ],
        "summary": "Consultar resumo salarial mensal",
        "operationId": "getMonthlySummary",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CompetenceDate"
          }
        ],
        "responses": {
          "200": {
            "description": "Resumo salarial retornado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MonthlySummaryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "put": {
        "tags": [
          "Summary"
        ],
        "summary": "Atualizar resumo financeiro do mês",
        "operationId": "updateMonthlySummary",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CompetenceDate"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateMonthlySummaryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resumo salarial atualizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MonthlySummaryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtido via Keycloak."
      }
    },
    "parameters": {
      "CompetenceDate": {
        "name": "competenceDate",
        "in": "path",
        "required": true,
        "description": "Competência no formato yyyy-MM-dd",
        "schema": {
          "type": "string",
          "format": "date",
          "example": "2026-06-01"
        }
      },
      "Page": {
        "name": "page",
        "in": "query",
        "required": false,
        "description": "Número da página (0-based)",
        "schema": { "type": "integer", "default": 0, "example": 0 }
      },
      "Size": {
        "name": "size",
        "in": "query",
        "required": false,
        "description": "Quantidade de itens por página",
        "schema": { "type": "integer", "default": 10, "example": 10 }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Requisição inválida",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorViolacaoResponse"
            },
            "example": {
              "status": 400,
              "error": "Requisição inválida",
              "message": "Salário líquido não pode ser maior que o salário bruto",
              "timestamp": "2026-05-03T19:00:00.000Z",
              "path": "/api/v1/finance/summary/2026-06-01",
              "violacoes": [
                {
                  "campo": "userNetSalary",
                  "razao": "Salário líquido não pode ser maior que o salário bruto"
                },
                {
                  "campo": "userGrossSalary",
                  "razao": "Salário bruto não pode ser menor que o salário líquido"
                }
              ]
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Falha na autenticação. Token ausente, inválido ou expirado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "status": 401,
              "error": "Não autorizado",
              "message": "Falha na autenticação. Token ausente, inválido ou expirado",
              "timestamp": "2026-05-03T19:00:00.000Z",
              "path": "/api/v1/ficance"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Acesso negado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "status": 403,
              "error": "Acesso negado",
              "message": "Você não tem permissão para acessar este recurso",
              "timestamp": "2026-05-03T19:00:00.000Z",
              "path": "/api/v1/ficance"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Erro interno do servidor",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "timestamp": "2026-05-03T19:00:00.000Z",
              "status": 500,
              "error": "Erro interno do servidor",
              "message": "Ocorreu um erro inesperado. Por favor, tente novamente mais tarde",
              "path": "/api/v1/ficance"
            }
          }
        }
      },
      "NotFound": {
        "description": "Não Encontrado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "status": 404,
              "error": "Não Encontrado",
              "message": "Objeto não encontrado",
              "timestamp": "2026-05-03T19:00:00.000Z",
              "path": "/api/v1/ficance"
            }
          }
        }
      }
    },
    "schemas": {
      "SalaryDetailResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64", "description": "ID do detalhe salarial", "example": 1 },
          "idType": { "type": "integer", "description": "ID do tipo de item (1=Desconto, 2=Provento, 3=Benefício)", "example": 1 },
          "code": { "type": "integer", "description": "Código do item", "example": 1001 },
          "name": { "type": "string", "description": "Nome do item", "example": "INSS" },
          "quantity": { "type": "integer", "description": "Quantidade", "example": 1 },
          "amount": { "type": "number", "format": "decimal", "description": "Valor monetário", "example": 150.00 }
        }
      },
      "SalaryDetailPageResponse": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SalaryDetailResponse" }
          },
          "totalElements": { "type": "integer", "format": "int64", "example": 3 },
          "totalPages": { "type": "integer", "example": 1 },
          "size": { "type": "integer", "example": 10 },
          "number": { "type": "integer", "example": 0 }
        }
      },
      "AddSalaryDetailRequest": {
        "type": "object",
        "required": ["idType", "code", "name", "quantity", "amount"],
        "properties": {
          "idType": { "type": "integer", "description": "ID do tipo (1=Desconto, 2=Provento, 3=Benefício)", "example": 1 },
          "code": { "type": "integer", "minimum": 1, "description": "Código único do item", "example": 1001 },
          "name": { "type": "string", "maxLength": 50, "description": "Nome do item", "example": "INSS" },
          "quantity": { "type": "integer", "minimum": 1, "description": "Quantidade", "example": 1 },
          "amount": { "type": "number", "format": "decimal", "minimum": 1, "description": "Valor monetário", "example": 150.00 }
        }
      },
      "UpdateSalaryDetailRequest": {
        "type": "object",
        "required": ["id", "idType", "code", "name", "quantity", "amount"],
        "properties": {
          "id": { "type": "integer", "format": "int64", "description": "ID do detalhe a editar", "example": 1 },
          "idType": { "type": "integer", "description": "ID do tipo (1=Desconto, 2=Provento, 3=Benefício)", "example": 1 },
          "code": { "type": "integer", "minimum": 1, "description": "Código único do item", "example": 1001 },
          "name": { "type": "string", "maxLength": 50, "description": "Nome do item", "example": "INSS" },
          "quantity": { "type": "integer", "minimum": 1, "description": "Quantidade", "example": 1 },
          "amount": { "type": "number", "format": "decimal", "minimum": 1, "description": "Valor monetário", "example": 150.00 }
        }
      },
      "DeleteSalaryDetailRequest": {
        "type": "object",
        "required": ["ids"],
        "properties": {
          "ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "integer", "format": "int64" },
            "description": "Lista de IDs de salary_detail a deletar",
            "example": [1, 2]
          }
        }
      },
      "MonthlySummaryResponse": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string",
            "description": "Nome do usuário",
            "example": "João"
          },
          "sobrenome": {
            "type": "string",
            "description": "Sobrenome do usuário",
            "example": "Silva"
          },
          "familyName": {
            "type": "string",
            "description": "Nome da família",
            "example": "Silva"
          },
          "userGrossSalary": {
            "type": "number",
            "format": "decimal",
            "description": "Salário bruto do usuário",
            "example": 5500.00
          },
          "familyGrossSalary": {
            "type": "number",
            "format": "decimal",
            "description": "Salário bruto total da família",
            "example": 13200.00
          },
          "userNetSalary": {
            "type": "number",
            "format": "decimal",
            "description": "Salário líquido do usuário",
            "example": 4800.00
          },
          "familyNetSalary": {
            "type": "number",
            "format": "decimal",
            "description": "Salário líquido total da família",
            "example": 11800.00
          }
        }
      },
      "UpdateMonthlySummaryRequest": {
        "type": "object",
        "required": [
          "userGrossSalary",
          "userNetSalary"
        ],
        "properties": {
          "userGrossSalary": {
            "type": "number",
            "format": "decimal",
            "minimum": 0,
            "description": "Salário bruto do usuário",
            "example": 5500.00
          },
          "userNetSalary": {
            "type": "number",
            "format": "decimal",
            "minimum": 0,
            "description": "Salário líquido do usuário",
            "example": 4800.00
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Data e hora do erro em UTC",
            "example": "2026-05-03T19:00:00.000Z"
          },
          "status": {
            "type": "integer",
            "description": "Código HTTP do erro",
            "example": 400
          },
          "error": {
            "type": "string",
            "description": "Descrição resumida do erro HTTP",
            "example": "Bad Request"
          },
          "message": {
            "type": "string",
            "description": "Mensagem detalhada do erro",
            "example": "Mensagem de erro"
          },
          "path": {
            "type": "string",
            "description": "Caminho do endpoint que gerou o erro",
            "example": "/api/v1/finance"
          }
        }
      },
      "ErrorViolacaoResponse": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Data e hora do erro em UTC"
          },
          "status": {
            "type": "integer",
            "description": "Código HTTP do erro",
            "example": 400
          },
          "error": {
            "type": "string",
            "description": "Descrição resumida do erro HTTP",
            "example": "Bad Request"
          },
          "violacoes": {
            "type": "array",
            "description": "Lista de violações de regras de negócio que causaram o erro",
            "items": {
              "$ref": "#/components/schemas/ViolacaoResponse"
            }
          },
          "path": {
            "type": "string",
            "description": "Caminho do endpoint que gerou o erro",
            "example": "/api/v1/ficance"
          },
          "message": {
            "type": "string",
            "description": "Mensagem detalhada do erro",
            "example": "Mensagem de erro"
          }
        }
      },
      "ViolacaoResponse": {
        "type": "object",
        "properties": {
          "campo": {
            "type": "string",
            "description": "Campo que violou a regra de negócio"
          },
          "razao": {
            "type": "string",
            "description": "Razão da violação de regra de negócio"
          }
        }
      }
    }
  }
}